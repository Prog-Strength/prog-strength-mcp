# Base URL of the Prog Strength API. Local dev points at the Go server on
# loopback; prod points at the public hostname (Caddy → api container).
PROG_STRENGTH_API_BASE_URL=http://localhost:8080

# HS256 secret used by the API to sign and verify JWTs. The MCP server uses
# the same secret to mint short-lived per-tool-call tokens for whichever
# user_id the caller specifies. MUST match the value in the API's .env.
JWT_SIGNING_KEY=replace-me

# Bind address for the FastMCP streamable-HTTP transport.
MCP_HOST=0.0.0.0
MCP_PORT=8000
