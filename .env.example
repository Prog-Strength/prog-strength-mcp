# Base URL of the Prog Strength API. Local dev points at the Go server on
# loopback; prod points at the public hostname (Caddy → api container).
PROG_STRENGTH_API_BASE_URL=http://localhost:8080

# Bind address for the FastMCP streamable-HTTP transport.
MCP_HOST=0.0.0.0
MCP_PORT=8000

# External nutrition data providers for lookup_food_nutrition. All
# optional — with none set the tool returns lookup_unavailable and the
# agent estimates macros itself.
#   FatSecret Platform (restaurant + branded foods, free Basic tier):
#   register at https://platform.fatsecret.com/register
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=
#   USDA FoodData Central (generic foods, free):
#   https://fdc.nal.usda.gov/api-key-signup
USDA_FDC_API_KEY=
